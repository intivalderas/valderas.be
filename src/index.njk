<!-- Contact -->
<section class="section section--contact" id="contact">
  <div class="section__header">
    <div class="label">Contact</div>
    <h2 class="section__title reveal">Let's work together</h2>
  </div>
  <div class="contact__content reveal">
    <div class="contact__toggles" role="group" aria-label="Pick two project priorities">
      <button class="contact__toggle magnetic-btn" type="button" data-toggle="cheap" aria-pressed="false">Cheap</button>
      <button class="contact__toggle magnetic-btn" type="button" data-toggle="fast" aria-pressed="false">Fast</button>
      <button class="contact__toggle magnetic-btn" type="button" data-toggle="good" aria-pressed="false">Good</button>
    </div>
    <p class="contact__status" aria-live="polite">Pick any two. That's the deal.</p>

    <form class="contact__form" id="contactForm" novalidate>
      <div class="contact__field">
        <label class="contact__label" for="contactName">Name</label>
        <input class="contact__input" type="text" id="contactName" name="name" required autocomplete="name">
      </div>
      <div class="contact__field">
        <label class="contact__label" for="contactEmail">Email</label>
        <input class="contact__input" type="email" id="contactEmail" name="email" required autocomplete="email">
      </div>
      <div class="contact__field">
        <label class="contact__label" for="contactMessage">Message</label>
        <textarea class="contact__textarea" id="contactMessage" name="message" rows="4" required></textarea>
      </div>
      <button class="contact__submit magnetic-btn" type="submit">
        <span>Send it</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7V17"/>
        </svg>
      </button>
    </form>

    <p class="contact__or">Or find me on</p>
    <div class="contact__links">
      <a href="https://linkedin.com/in/inti-valderas-caro" class="contact__link magnetic-btn" target="_blank" rel="noopener noreferrer">LinkedIn<span class="sr-only"> (opens in new tab)</span></a>
      <a href="https://github.com/intivalderas" class="contact__link magnetic-btn" target="_blank" rel="noopener noreferrer">GitHub<span class="sr-only"> (opens in new tab)</span></a>
    </div>
  </div>
</section>

