<!-- Mobile hamburger -->
<button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="sidebar">
  <span class="sidebar-toggle__bar"></span>
  <span class="sidebar-toggle__bar"></span>
  <span class="sidebar-toggle__bar"></span>
</button>

<!-- Sidebar Navigation -->
<aside class="sidebar" id="sidebar" aria-label="Main navigation">
  <div class="sidebar__content">
    <div class="sidebar__top">
      <a href="/" class="sidebar__logo" aria-label="Inti Valderas Caro — Home">
        <svg class="sidebar__logo-mark" width="100" height="100" viewBox="0 0 118 118" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
