      <button class="sidebar__link sidebar__link--small" id="cookieSettings" type="button">Cookie settings</button>
      <a href="/accessibility/" class="sidebar__link sidebar__link--small">Accessibility</a>
      <a href="/credits/" class="sidebar__link sidebar__link--small">Credits</a>
      <p class="sidebar__copyright">&copy; 2026 Inti Valderas Caro</p>
    </div>
  </div>
</aside>
