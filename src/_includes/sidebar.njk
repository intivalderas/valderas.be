        </svg>
        <span>Inti Valderas Caro</span>
      </a>
    </div>
    <nav class="sidebar__center">
      <div class="sidebar__links">
        <a href="{% if isHome %}#work{% else %}/#work{% endif %}" class="sidebar__link">Work</a>
        <a href="{% if isHome %}#about{% else %}/#about{% endif %}" class="sidebar__link">About</a>
        <a href="{% if isHome %}#contact{% else %}/#contact{% endif %}" class="sidebar__link">Contact</a>
        <button class="sidebar__link sidebar__link--btn" id="resumeToggle" type="button">Resume</button>
      </div>
    </nav>
    <div class="sidebar__bottom">
      <!-- Settings -->
      <div class="settings" id="settingsPanel">
        <button class="sidebar__link sidebar__link--small" id="settingsToggle" type="button" aria-expanded="false" aria-controls="settingsMenu">Toggle things</button>
        <div class="settings__menu" id="settingsMenu">
          <div class="settings__group">
            <span class="settings__group-label">Theme</span>
            <div class="settings__item">
              <label class="settings__label" for="settingDarkMode">Dark mode</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingDarkMode">
                <span class="settings__slider"></span>
              </label>
            </div>
          </div>
          <div class="settings__separator"></div>
          <div class="settings__group">
            <span class="settings__group-label">Effects</span>
            <div class="settings__item">
              <label class="settings__label" for="settingParticles">Particles</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingParticles" checked>
                <span class="settings__slider"></span>
              </label>
            </div>
            <div class="settings__item">
              <label class="settings__label" for="settingMotion">Motion effects</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingMotion" checked>
                <span class="settings__slider"></span>
              </label>
            </div>
            <div class="settings__item" id="settingCursorRow">
              <label class="settings__label" for="settingCursor">Custom cursor</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingCursor" checked>
                <span class="settings__slider"></span>
              </label>
            </div>
            <div class="settings__item" id="settingGyroRow">
              <label class="settings__label" for="settingGyroscope">Gyroscope</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingGyroscope">
                <span class="settings__slider"></span>
              </label>
            </div>
            <div class="settings__separator"></div>
            <div class="settings__item">
              <label class="settings__label" id="settingDisableAllLabel" for="settingDisableAll">Disable all</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingDisableAll">
                <span class="settings__slider"></span>
              </label>
            </div>
          </div>
          <div class="settings__separator"></div>
          <div class="settings__group">
            <span class="settings__group-label">Privacy</span>
            <div class="settings__item">
              <label class="settings__label" for="settingAnalytics">Analytics</label>
              <label class="settings__switch">
                <input type="checkbox" id="settingAnalytics">
                <span class="settings__slider"></span>
              </label>
            </div>
            <button class="settings__details-link" id="settingsCookieDetails" type="button">What gets tracked?</button>
          </div>
        </div>
      </div>
